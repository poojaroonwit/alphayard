# AI Service Configuration Template
# Copy this file to .env and fill in your values

# ------------------------------------------------------------------------------
# API Keys (at least one is required)
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
# Must match the JWT_SECRET used by the bondary-backend
JWT_SECRET=your_shared_jwt_secret_change_me

# Admin secret for accessing AI dashboard and admin endpoints
AI_ADMIN_SECRET=ai-admin-secret-change-me

# ------------------------------------------------------------------------------
# Infrastructure & Integration
# ------------------------------------------------------------------------------
# Redis connection for chat history and rate limiting
REDIS_URL=redis://localhost:6379

# URL of the main backend API
BONDARY_BACKEND_URL=http://localhost:4000

# Port for this AI service to listen on
PORT=5001

# Default LLM model to use if not specified in config
DEFAULT_MODEL=claude-3-5-sonnet-20240620
